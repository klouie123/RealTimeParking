<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RealTimeParkingApp.Views.LoginPage"
             Title="LoginPage">

    <StackLayout Padding="20" Spacing="15" VerticalOptions="Center">
        <Label Text="Welcome to Real-Time Parking App" FontSize="24" HorizontalOptions="Center" />

        <Entry x:Name="UsernameOrEmailEntry" Placeholder="Username or Email" />
        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" />

        <Button Text="Login" Clicked="LoginButton_Clicked" />
        <Button Text="Register" Clicked="RegisterButton_Clicked" />

        <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False"/>
    </StackLayout>
</ContentPage>