<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RealTimeParkingApp.Views.ParkingSlotsPage"
             Title="ParkingSlotsPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label x:Name="LocationNameLabel"
                   Text="Parking Location"
                   FontSize="24"
                   FontAttributes="Bold" />

            <CollectionView x:Name="SlotsCollectionView">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="5" Padding="10" CornerRadius="12">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding SlotCode}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Status}" FontSize="14" />

                                <Button Text="Reserve"
                                        Clicked="ReserveButton_Clicked"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>