<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:vm="clr-namespace:RealTimeParkingApp.ViewModels"
             x:Class="RealTimeParkingApp.Views.MapPage"
             Title="Map">

    <Grid>
        <maps:Map x:Name="map"
                  IsShowingUser="True" />

        <Frame BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}"
               BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}"
               CornerRadius="24"
               Padding="12"
               HasShadow="False"
               VerticalOptions="End"
               Margin="12"
               HeightRequest="320">

            <CollectionView ItemsSource="{Binding Parkings}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,0,0,10"
                               Padding="12"
                               CornerRadius="12"
                               HasShadow="False"
                               BackgroundColor="{AppThemeBinding Light=#F9FAFB, Dark=#111827}"
                               BorderColor="{Binding IsSelected, Converter={StaticResource BoolToColorConverter}}">

                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />

                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

                                <Label Text="{Binding Distance, StringFormat='Distance: {0:F2} km'}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#16A34A, Dark=#4ADE80}" />

                                <Button Text="Navigate"
                                        BackgroundColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                                        TextColor="{AppThemeBinding Light=White, Dark=#111827}"
                                        CornerRadius="12"
                                        Margin="0,6,0,0"
                                        Clicked="OnNavigateClicked"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnParkingTapped"
                                                      CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Frame>
    </Grid>
</ContentPage>