<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RealTimeParkingApp.ViewModels"
             x:Class="RealTimeParkingApp.Views.AdminDashboardPage"
             Title="Admin Dashboard"
             BackgroundColor="{AppThemeBinding Light=#F8F9FB, Dark=#0F172A}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="☰"
                     Priority="0"
                     Order="Primary"
                     Clicked="HamburgerButton_Clicked"/>
    </ContentPage.ToolbarItems>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">

                <Label Text="Welcome, Admin!"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />

                <Label x:Name="UsernameLabel"
                       FontSize="16"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />

                <Button Text="Manage Users"
                        Clicked="ManageUsers_Clicked"
                        BackgroundColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                        TextColor="{AppThemeBinding Light=White, Dark=#111827}"
                        CornerRadius="12"
                        HeightRequest="48"/>

                <Button Text="Manage Parking Locations"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
                        BorderColor="{AppThemeBinding Light=#D1D5DB, Dark=#334155}"
                        BorderWidth="1"
                        CornerRadius="12"
                        HeightRequest="48"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="FlyoutPanel"
              BackgroundColor="{AppThemeBinding Light=#DDFFFFFF, Dark=#CC0F172A}"
              WidthRequest="250"
              HorizontalOptions="End"
              IsVisible="False"
              TranslationX="250">

            <VerticalStackLayout Padding="20" Spacing="20"
                                 BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}">
                <Label x:Name="FlyoutUsernameLabel"
                       FontSize="20"
                       TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}" />

                <Label Text="{Binding Email}"
                       FontSize="16"
                       TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>

                <Label Text="{Binding Role}"
                       FontSize="16"
                       TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"/>

                <Button Text="Logout"
                        Clicked="LogoutButton_Clicked"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}"
                        TextColor="{AppThemeBinding Light=#B91C1C, Dark=#FCA5A5}"
                        BorderColor="{AppThemeBinding Light=#FCA5A5, Dark=#7F1D1D}"
                        BorderWidth="1"
                        CornerRadius="12"
                        HeightRequest="48"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>