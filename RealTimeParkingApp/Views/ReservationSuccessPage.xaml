<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RealTimeParkingApp.Views.ReservationSuccessPage"
             Title="Success"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F8F9FB, Dark=#0F172A}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Payment Successful"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#059669, Dark=#6EE7B7}" />

            <Label Text="Thank you for using our parking service."
                   FontSize="15"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light=#6B7280, Dark=#CBD5E1}" />

            <Frame CornerRadius="16"
                   Padding="16"
                   HasShadow="False"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}"
                   BorderColor="{AppThemeBinding Light=#E5E7EB, Dark=#334155}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Receipt Details"
                           FontSize="16"
                           FontAttributes="Bold" />
                    <Label x:Name="LocationLabel" FontSize="14" />
                    <Label x:Name="SlotLabel" FontSize="14" />
                    <Label x:Name="ReservationReferenceLabel" FontSize="14" />
                    <Label x:Name="PaymentReferenceLabel" FontSize="14" />
                    <Label x:Name="PaymentMethodLabel" FontSize="14" />
                    <Label x:Name="AmountLabel" FontSize="14" FontAttributes="Bold" />
                    <Label x:Name="StatusLabel" FontSize="14" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Done"
                    Clicked="Done_Clicked"
                    BackgroundColor="#111827"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="48" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>