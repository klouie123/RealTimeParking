<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RealTimeParkingApp.Views.UserDashboardPage"
             Title="Dashboard">

    <Grid>
        <Frame x:Name="NavigationBanner"
               IsVisible="False"
               BackgroundColor="#E8F5E9"
               CornerRadius="16"
               Padding="10"
               Margin="10"
               VerticalOptions="End">

            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout>
                    <Label Text="You are navigating"
                           FontAttributes="Bold" />
                    <Label x:Name="NavigationBannerLabel"
                           Text="Tap to return to navigation"
                           FontSize="12" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Open"
                        Clicked="OpenNavigationBanner_Clicked" />
            </Grid>
        </Frame>

        <StackLayout Padding="20" Spacing="15">
            <Label Text="Available Parking Locations"
                   FontSize="20"
                   FontAttributes="Bold" />

            <CollectionView x:Name="ParkingLocationsCollectionView">
                <CollectionView.EmptyView>
                    <Label Text="No parking locations found."
                           FontSize="16"
                           TextColor="Gray"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="5" Padding="10" CornerRadius="12">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="Gray" />
                                <Button Text="View Slots"
                                        Clicked="ViewSlots_Clicked"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="My Reserved Parking"
                    Clicked="OpenActiveReservation_Clicked"/>
        </StackLayout>
        <Frame x:Name="ReservedPanel"
       IsVisible="False"
       BackgroundColor="White"
       CornerRadius="20"
       Padding="15"
       Margin="10"
       VerticalOptions="End"
       HasShadow="True">

            <VerticalStackLayout Spacing="10">
                <Label Text="My Reserved Parking"
               FontSize="20"
               FontAttributes="Bold" />

                <Label x:Name="ReservedLocationLabel" Text="Location" />
                <Label x:Name="ReservedSlotLabel" Text="Slot" />
                <Label x:Name="ReservedStatusLabel" Text="Status" />
                <Label x:Name="ReservedExpiryLabel" Text="Expires At" />

                <HorizontalStackLayout Spacing="10">
                    <Button Text="Navigate"
                    Clicked="NavigateReserved_Clicked"
                    HorizontalOptions="FillAndExpand" />

                    <Button Text="Cancel Reservation"
                    Clicked="CancelReserved_Clicked"
                    HorizontalOptions="FillAndExpand" />
                </HorizontalStackLayout>

                <Button Text="Close"
                Clicked="CloseReservedPanel_Clicked" />
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>