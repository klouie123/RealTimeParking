<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       x:Class="RealTimeParkingApp.Shells.UserShell"
       xmlns:views="clr-namespace:RealTimeParkingApp.Views"
       Title="RealTimeParkingApp">

    <TabBar>
        <ShellContent
            Title="Home"
            Icon="home.png"
            Route="UserDashboardPage"
            ContentTemplate="{DataTemplate views:UserDashboardPage}" />

        <ShellContent
            Title="Profile"
            Icon="profile.png"
            Route="ProfilePage"
            ContentTemplate="{DataTemplate views:ProfilePage}" />
    </TabBar>
</Shell>
