<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       x:Class="RealTimeParkingApp.Shells.AdminShell"
       Title="RealTimeParkingApp"
       Shell.BackgroundColor="{AppThemeBinding Light=White, Dark=#0F172A}"
       Shell.ForegroundColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
       Shell.TitleColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
       Shell.DisabledColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"
       Shell.UnselectedColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
       Shell.TabBarBackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}"
       Shell.TabBarForegroundColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
       Shell.TabBarUnselectedColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}"
       Shell.TabBarTitleColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}"
       Shell.TabBarDisabledColor="{AppThemeBinding Light=#9CA3AF, Dark=#64748B}"
       Shell.NavBarHasShadow="False">

    <TabBar>
        <ShellContent x:Name="AdminDashboardContent"
                      Title="Dashboard"
                      Route="AdminDashboardPage" />
    </TabBar>
</Shell>